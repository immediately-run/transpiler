{
  "name": "@immediately-run/transpiler",
  "version": "0.1.0",
  "description": "The single source of truth for immediately.run's per-file transform chain (Babel + react-refresh), shared byte-for-byte between the browser sandbox bundler and the CLI's pre-transpiled-artifact emitter.",
  "license": "MIT",
  "repository": "github:immediately-run/transpiler",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "gen:version": "node scripts/gen-version.mjs",
    "prebuild": "node scripts/gen-version.mjs",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "gen:golden": "node scripts/gen-golden.mjs",
    "test": "npm run build && node --test test/*.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@babel/plugin-proposal-explicit-resource-management": "7.25.9",
    "@babel/standalone": "7.27.0",
    "react-refresh": "0.17.0"
  },
  "devDependencies": {
    "@types/babel__standalone": "7.1.9",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
