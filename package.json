{
  "name": "@immediately-run/transpiler",
  "version": "0.6.0",
  "description": "The single source of truth for immediately.run's per-file transform chain (MDX + Babel + react-refresh), shared byte-for-byte between the browser sandbox bundler and the CLI's pre-transpiled-artifact emitter.",
  "license": "MIT",
  "repository": "github:immediately-run/transpiler",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "worker"
  ],
  "sideEffects": false,
  "scripts": {
    "gen:version": "node scripts/gen-version.mjs",
    "prebuild": "node scripts/gen-version.mjs",
    "build": "tsup",
    "build:worker": "node scripts/build-worker.mjs",
    "typecheck": "tsc --noEmit",
    "gen:golden": "node scripts/gen-golden.mjs",
    "test": "npm run build && node --test test/*.test.mjs",
    "test:worker": "npm run build && npm run build:worker && node --test test/babel-worker.harness.mjs",
    "prepublishOnly": "npm run build && npm run build:worker"
  },
  "dependencies": {
    "@babel/plugin-proposal-explicit-resource-management": "7.25.9",
    "@babel/standalone": "7.27.0",
    "@immediately-run/mdx-plugins": "file:../immediately-run-mdx-plugins",
    "@immediately-run/worker-transport": "^0.1.0",
    "@mdx-js/mdx": "3.1.0",
    "react-refresh": "0.17.0",
    "remark-gfm": "4.0.1",
    "yaml": "2.7.1"
  },
  "devDependencies": {
    "@types/babel__standalone": "7.1.9",
    "@types/mdast": "4.0.4",
    "assert": "^2.1.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "esbuild": "^0.27.0",
    "events": "^3.3.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "string_decoder": "^1.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "unified": "11.0.5",
    "vm-browserify": "^1.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
